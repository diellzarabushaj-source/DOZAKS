{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "db-client.js", "use": "@vercel/static" },
    { "src": "ux.js", "use": "@vercel/static" },
    { "src": "drug-card-sync.js", "use": "@vercel/static" },
    { "src": "product-catalog.js", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    {
      "source": "/api/clinical-data",
      "destination": "https://mjeku-ks.netlify.app/api/clinical-data"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
